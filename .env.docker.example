# Firebase Cloud Function Configuration
# Diese Werte nach dem Deploy eintragen!

# Die URL deiner deployed Firebase Cloud Function
# Findest du nach: firebase deploy --only functions
FUNCTION_URL=https://europe-west1-moneyboy-2f088.cloudfunctions.net/checkSubscriptionsDaily

# Das Secret Token aus functions/.env (CRON_SECRET)
# Generiere mit: openssl rand -hex 32
CRON_TOKEN=dein-secret-token-hier-generieren

# Zeitzone für Cronjob (nicht ändern)
TZ=Europe/Berlin
